rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /leaderboard/{scoreId} {
      allow read: if true;
      allow create: if true;
    }

    function isValidScore(data) {
      return data.playerName is string && data.playerName.size() <= 50 &&
             data.level is string && data.level.size() <= 50 &&
             data.turns is number && data.turns >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.timestamp is timestamp;
    }
  }
}
